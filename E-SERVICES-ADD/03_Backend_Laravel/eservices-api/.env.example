APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# smtp | log | array
# Mot de passe oublié : le backend envoie d’abord via EmailJS si EMAILJS_ENABLED + clés OK ; sinon ce mailer.
# Avec MAIL_MAILER=log le code est seulement dans storage/logs/laravel.log — pas de vraie boîte. Pour un vrai e-mail : remplir EmailJS, ou MAIL_MAILER=smtp + Mailpit (ex. 127.0.0.1:1025).
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Notifications demandes (e-mails) ---
# true = envoyer les mails (statut, commentaires, assignation). false = désactiver.
MAIL_REQUEST_NOTIFICATIONS=true
# true = e-mail aux comptes « client » quand le service est publié / ouvert sur le portail (pas si « non publié »). false = désactiver.
# Dates de publication programmées : commande planifiée `services:notify-published-clients` (chaque minute via
# `php artisan schedule:work` en local, ou cron `* * * * * php artisan schedule:run` en prod).
# Secours : un GET sur le catalogue public `/api/services` déclenche aussi ce balayage (max 1× / ~55 s).
MAIL_NEW_SERVICE_TO_CLIENTS=true
# Fuseau pour les dates dans ces e-mails (ex. Africa/Casablanca).
MAIL_DISPLAY_TIMEZONE=Africa/Casablanca
# Signature « Cordialement » des e-mails notifications (défaut : L'équipe ADD-Services).
MAIL_TEAM_SIGNATURE="L'équipe ADD-Services"
# URL du front React (liens « Voir ma demande »). Ex. http://localhost:5173
FRONTEND_URL="${APP_URL}"

# Les notifications sont envoyées tout de suite (sync). Si QUEUE_CONNECTION=database|redis,
# pensez à lancer : php artisan queue:work (si vous passez les Mailable en ShouldQueue).

# --- EmailJS (e-mails vers les clients : notifications demande + « E-mails clients » admin) ---
# true = Laravel appelle l’API EmailJS. Clés : .env ci-dessous OU storage/app/emailjs-credentials.json (php artisan emailjs:setup)
# Modèle : to_email, to_name, title, message, name, email
EMAILJS_ENABLED=false
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
# EMAILJS_PRIVATE_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
