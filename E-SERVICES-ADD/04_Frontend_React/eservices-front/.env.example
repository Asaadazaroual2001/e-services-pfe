# Base URL pour l'API Laravel
VITE_API_BASE_URL=http://localhost:8000

# Optionnel: Activer les logs de debug
VITE_DEBUG=false

# Optionnel: Nom de l'application 
VITE_APP_NAME=E-Services

# --- EmailJS (page /contact, envoi depuis le navigateur) ---
# Créez un compte sur https://www.emailjs.com/ : Email Services + Email Template.
# Variables du modèle attendues par l’app : user_name, user_email, message
# VITE_EMAILJS_PUBLIC_KEY = clé publique (Public Key / User ID du compte)
# Même SERVICE_ID / TEMPLATE_ID / PUBLIC_KEY que côté Laravel (.env : EMAILJS_*), si vous utilisez le même modèle.
# Si vide, l’app peut charger ces identifiants via GET {VITE_API_BASE_URL}/api/public/emailjs-config.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=